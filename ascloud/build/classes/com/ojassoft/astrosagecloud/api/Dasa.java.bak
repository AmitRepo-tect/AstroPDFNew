	/**
	 * Creates DesktopHoro object
	 * @param name
	 * @param day
	 * @param month
	 * @param year
	 * @param hrs
	 * @param min
	 * @param sec
	 * @param latDeg
	 * @param latMin
	 * @param latNS
	 * @param longDeg
	 * @param longMin
	 * @param longEW
	 * @param timeZone
	 * @return
	 */
	public static Dasa createHoro(String name, String day, String month, String year, String hrs, String min, String sec, String latDeg, String latMin, String latNS, String longDeg, String longMin, String longEW, String timeZone,String path) {

		Constants const1 = new Constants();
		const1.setConstPath(path);

		Dasa phoro = new Dasa();
		
		try {

			phoro.setCompanyName("CSL SOFTWARE LTD., G-4A, Green park Extn., New Delhi-110 016");
			phoro.setCompanyAddLine1("Phone:011-6867329, 9811356741, E-Mail: info@astrocamp.com http://www.astrocamp.com");
			phoro.setName(name);
			phoro.setPlace("agra");
			phoro.setTimeZone(timeZone);
			phoro.setMaleFemale("M");
			phoro.setSecondOfBirth(sec);
			phoro.setMinuteOfBirth(min);
			phoro.setHourOfBirth(hrs);
			phoro.setDayOfBirth(day);
			phoro.setMonthOfBirth(month);
			phoro.setYearOfBirth(year);
			phoro.setDegreeOfLattitude(latDeg);
			phoro.setDegreeOfLongitude(longDeg);
			phoro.setSecondOfLattitude("00");
			phoro.setSecondOfLongitude("00");
			phoro.setMinuteOfLongitude(longMin);
			phoro.setMinuteOfLattitude(latMin);
			phoro.setEastWest(longEW);
			phoro.setNorthSouth(latNS);
			phoro.setLanguageCode("0");
			phoro.setDST("0");
			phoro.setAyanamsaType(1);
			// phoro.setAyanamsaType(3);
			phoro.setLanguageCode("0");
			// phoro.setCustomizedAyanamsa("23.000");
			phoro.initialize();
		} catch (Exception ex) {
			ex.printStackTrace();
		}

		return phoro;
		
	}	
	
	
	public class Pdasa {
		int mdasa;
		int adasa;
		int pdasa;
		double pdasaStartDate;
		double pdasaEndDate;
		
		//protected String x9[] = new String[9];
		protected String x9[] = {"Ketu   ", "Venus  ", "Sun    ", "Moon   ", "Mars   ", "Rahu   ", "Jupiter", "Saturn ", "Mercury"}; 
		
		Pdasa(int mdasa,int adasa,int pdasa,double pdasaStartDate,double pdasaEndDate) {
			this.mdasa = mdasa;
			this.adasa=adasa;
			this.pdasa =pdasa;
			this.pdasaStartDate=pdasaStartDate;
			this.pdasaEndDate=pdasaEndDate;
		}
		public int getMdasa() {
			return this.mdasa;
		}
		public int getAdasa() {
			return this.adasa;
		}
		public int getPdasa() {
			return this.pdasa;
		}
		public double getPdasaStartDate() {
			return this.pdasaStartDate;
		}
		public double getPdasaEndDate() {
			return this.pdasaEndDate;
		}
		public String toString() {
			//return mdasa + "-" + adasa + "-" + pdasa + ": " + pdasaEndDate;
			if (pdasa != -1)
				return x9[mdasa] + "-" + x9[adasa] + "-" + x9[pdasa] + ": " + doubleToDate(pdasaStartDate) + "-" + doubleToDate(pdasaEndDate);
			else
				return x9[mdasa] + "-" + x9[adasa] + ": " + doubleToDate(pdasaStartDate) + "-" + doubleToDate(pdasaEndDate);
		}
		public String doubleToDate(double m2) {
			int p = (int) m2;
			int r = (int) (12 * utilDesktop.fract(m2));
			int t = (int) (30 * utilDesktop.fract(12 * utilDesktop.fract(m2)) + 1);
			if (r == 0) {
				p--;
				r = 12;
			} else
				if (r == 2 && t > 28) {
					t -= 28;
					r = 3;
				}
			String date = utilDesktop.ymd(p, r, t);
			return date;
		}
	}
	


}
